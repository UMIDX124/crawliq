// CrawlIQ database — ported from AGENTS-HUB, refined for Clerk + Postgres.
//
// Auth source of truth: Clerk (clerkUserId on User row).
// Audit pipeline: Groq (single provider). Multi-provider fallback dropped.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  OWNER
  ADMIN
  SPECIALIST
  CLIENT
}

enum AuditStatus {
  PENDING
  RUNNING
  COMPLETED
  FAILED
}

enum AgentType {
  ONPAGE
  TECHNICAL
  OFFSITE
  CONTENT
  COMPETITOR
}

enum TaskStatus {
  TODO
  IN_PROGRESS
  DONE
  CANCELLED
}

enum TaskPriority {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum Severity {
  PASS
  WARNING
  CRITICAL
}

enum Plan {
  FREE
  PRO
  AGENCY
}

enum BillingCycle {
  MONTHLY
  ANNUAL
}

enum SubscriptionStatus {
  TRIALING
  ACTIVE
  PAST_DUE
  CANCELED
  INCOMPLETE
}

model User {
  id          String   @id @default(cuid())
  clerkUserId String   @unique
  email       String   @unique
  name        String
  avatarUrl   String?
  role        Role     @default(SPECIALIST)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  audits                  Audit[]                   @relation("AuditCreatedBy")
  ownedProjects           Project[]                 @relation("ProjectOwner")
  projectMembers          ProjectMember[]
  assignedTasks           Task[]                    @relation("AssignedTasks")
  createdTasks            Task[]                    @relation("CreatedTasks")
  pins                    Pin[]
  subscription            Subscription?
  searchConsoleConnection SearchConsoleConnection?

  @@index([email])
  @@index([clerkUserId])
}

model SearchConsoleConnection {
  id            String   @id @default(cuid())
  userId        String   @unique
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  email         String
  accessToken   String
  refreshToken  String
  expiresAt     DateTime
  scope         String
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model Subscription {
  id                   String              @id @default(cuid())
  userId               String              @unique
  user                 User                @relation(fields: [userId], references: [id], onDelete: Cascade)

  stripeCustomerId     String              @unique
  stripeSubscriptionId String?             @unique
  stripePriceId        String?

  plan                 Plan                @default(FREE)
  billingCycle         BillingCycle?
  status               SubscriptionStatus  @default(INCOMPLETE)

  currentPeriodEnd     DateTime?
  cancelAtPeriodEnd    Boolean             @default(false)

  createdAt            DateTime            @default(now())
  updatedAt            DateTime            @updatedAt

  @@index([stripeCustomerId])
}

model Project {
  id          String          @id @default(cuid())
  name        String
  url         String
  description String?
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt

  ownerId     String
  owner       User            @relation("ProjectOwner", fields: [ownerId], references: [id], onDelete: Cascade)

  members     ProjectMember[]
  audits      Audit[]
  tasks       Task[]

  @@index([ownerId])
}

model ProjectMember {
  id        String   @id @default(cuid())
  role      Role     @default(SPECIALIST)
  createdAt DateTime @default(now())

  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  projectId String
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@unique([userId, projectId])
}

model Audit {
  id        String       @id @default(cuid())
  url       String
  agent     AgentType
  status    AuditStatus  @default(PENDING)
  score     Int?
  grade     String?
  summary   String?
  // raw signal capture (cheerio crawl output)
  signals   Json?
  // structured findings list (matches src/lib/audit.ts AuditResult schema)
  data      Json?
  errorMsg  String?
  startedAt DateTime?
  endedAt   DateTime?
  createdAt DateTime     @default(now())

  userId    String
  user      User         @relation("AuditCreatedBy", fields: [userId], references: [id], onDelete: Cascade)
  projectId String?
  project   Project?     @relation(fields: [projectId], references: [id], onDelete: SetNull)

  findings  Finding[]
  tasks     Task[]

  @@index([userId])
  @@index([projectId])
  @@index([createdAt])
}

model Finding {
  id        String    @id @default(cuid())
  title     String
  detail    String
  category  String
  severity  Severity
  createdAt DateTime  @default(now())

  auditId   String
  audit     Audit     @relation(fields: [auditId], references: [id], onDelete: Cascade)

  @@index([auditId])
}

model Task {
  id          String        @id @default(cuid())
  title       String
  description String?
  status      TaskStatus    @default(TODO)
  priority    TaskPriority  @default(MEDIUM)
  dueDate     DateTime?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  creatorId   String
  creator     User          @relation("CreatedTasks", fields: [creatorId], references: [id], onDelete: Cascade)
  assigneeId  String?
  assignee    User?         @relation("AssignedTasks", fields: [assigneeId], references: [id], onDelete: SetNull)

  projectId   String?
  project     Project?      @relation(fields: [projectId], references: [id], onDelete: Cascade)
  auditId     String?
  audit       Audit?        @relation(fields: [auditId], references: [id], onDelete: SetNull)

  @@index([assigneeId])
  @@index([projectId])
  @@index([status])
}

model Pin {
  id        String   @id @default(cuid())
  title     String
  detail    String
  agent     String?
  severity  Severity?
  createdAt DateTime @default(now())

  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model PilotLead {
  id              String   @id @default(cuid())
  name            String
  email           String
  company         String
  websiteUrl      String
  monthlyTraffic  String?
  message         String?
  ip              String?
  createdAt       DateTime @default(now())

  @@index([email])
  @@index([createdAt])
}
