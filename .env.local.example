# === CrawlIQ env ===
# Copy to .env.local and fill in real values.
# DO NOT commit .env.local to git.

# === Auth: Clerk ===
# Get keys: https://dashboard.clerk.com/last-active?path=api-keys
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=
# Optional Clerk routing overrides (defaults work for most setups)
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_SIGN_IN_FORCE_REDIRECT_URL=/dashboard
NEXT_PUBLIC_CLERK_SIGN_UP_FORCE_REDIRECT_URL=/dashboard

# === Database: Postgres (Neon recommended via Vercel Marketplace) ===
# Vercel Marketplace → Neon → auto-provisions DATABASE_URL.
# Or get a free DB at https://neon.tech
DATABASE_URL=

# === Groq: powers the AI audit explanations ===
# Get a key: https://console.groq.com/keys
GROQ_API_KEY=

# === Google PageSpeed Insights + CrUX: real Lighthouse + real-user data ===
# Same key works for BOTH PageSpeed Insights AND Chrome UX Report.
# Without it you're rate-limited (~10 req/min unauth) instead of 25,000/day.
# Free key: https://console.cloud.google.com/apis/library/pagespeedonline.googleapis.com
GOOGLE_PAGESPEED_API_KEY=

# === Google OAuth (for Search Console connection) ===
# Create at: https://console.cloud.google.com/apis/credentials
#   - OAuth 2.0 Client ID type "Web application"
#   - Authorized redirect URI: ${NEXT_PUBLIC_SITE_URL}/api/search-console/callback
#   - Enable "Google Search Console API" in APIs & Services library
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
# Optional: override redirect URI (defaults to {NEXT_PUBLIC_SITE_URL}/api/search-console/callback)
GOOGLE_OAUTH_REDIRECT_URI=

# === OpenPageRank (free DA-proxy score, optional) ===
# 1000 queries/day free. Sign up: https://www.domcop.com/openpagerank/
OPENPAGERANK_API_KEY=

# === Resend: pilot leads + audit-report email (optional) ===
# Get a key: https://resend.com/api-keys
RESEND_API_KEY=
# Verified sending domain. Until verified, use "onboarding@resend.dev"
RESEND_FROM_EMAIL=audit@crawliq.ai
# Where pilot lead notifications are sent
LEAD_NOTIFICATION_EMAIL=backupsolutions1122@gmail.com

# === Public site URL — used for OG image, canonical, sitemap ===
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# === Stripe: subscription billing for Pro / Agency ===
# Get keys: https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=
# Webhook signing secret. See https://dashboard.stripe.com/webhooks
# When testing locally, run: stripe listen --forward-to localhost:3000/api/stripe/webhook
STRIPE_WEBHOOK_SECRET=

# Stripe Price IDs (create 4 prices in Stripe dashboard:
#   Pro $49/mo, Pro $39/mo billed yearly,
#   Agency $149/mo, Agency $119/mo billed yearly)
STRIPE_PRICE_PRO_MONTHLY=
STRIPE_PRICE_PRO_ANNUAL=
STRIPE_PRICE_AGENCY_MONTHLY=
STRIPE_PRICE_AGENCY_ANNUAL=
