# === CrawlIQ env ===
# Copy to .env.local and fill in real values.
# DO NOT commit .env.local to git.

# Groq — powers the AI auditor (llama-3.3-70b-versatile)
# Get a key: https://console.groq.com/keys
GROQ_API_KEY=

# Resend — pilot lead emails + audit-report delivery
# Get a key: https://resend.com/api-keys
RESEND_API_KEY=
# Verified sending domain. Until the domain is verified, use "onboarding@resend.dev"
RESEND_FROM_EMAIL=audit@crawliq.ai
# Where pilot lead notifications are sent
LEAD_NOTIFICATION_EMAIL=backupsolutions1122@gmail.com

# Public URLs (used for OG, canonical, CTA links)
NEXT_PUBLIC_SITE_URL=http://localhost:3000
NEXT_PUBLIC_APP_URL=https://agents-hub-fawn.vercel.app
