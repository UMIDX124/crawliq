{
  "name": "crawliq",
  "version": "0.1.0",
  "private": true,
  "description": "CrawlIQ — AI-powered website audit platform marketing & demo site",
  "scripts": {
    "dev": "next dev --turbopack",
    "build": "prisma generate && next build",
    "start": "next start",
    "lint": "eslint",
    "postinstall": "prisma generate",
    "db:push": "dotenv -e .env.local -- prisma db push",
    "db:studio": "dotenv -e .env.local -- prisma studio",
    "db:migrate": "dotenv -e .env.local -- prisma migrate dev"
  },
  "dependencies": {
    "@clerk/nextjs": "7.2.9",
    "@phosphor-icons/react": "2.1.10",
    "@prisma/client": "^6.19.3",
    "@react-pdf/renderer": "4.5.1",
    "@react-three/drei": "10.7.7",
    "@react-three/fiber": "9.6.1",
    "cheerio": "1.2.0",
    "framer-motion": "12.38.0",
    "groq-sdk": "1.1.2",
    "gsap": "3.15.0",
    "lenis": "1.3.23",
    "next": "16.2.4",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "resend": "6.12.2",
    "svix": "1.92.2",
    "three": "0.184.0",
    "zod": "4.4.1"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/cheerio": "1.0.0",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@types/three": "0.184.0",
    "dotenv-cli": "11.0.0",
    "eslint": "^9",
    "eslint-config-next": "16.2.4",
    "prisma": "^6.19.3",
    "tailwindcss": "^4",
    "typescript": "^5"
  }
}
